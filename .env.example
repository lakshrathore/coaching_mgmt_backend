PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=coaching_management

# REQUIRED: Generate a strong random string (at least 64 chars)
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRE=7d

CLIENT_URL=http://localhost:3000

# Email (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Your Coaching <your_email@gmail.com>

# MSG91 SMS / WhatsApp (get from msg91.com)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=COACHG
MSG91_WHATSAPP_INTEGRATED_NUMBER=
MSG91_WHATSAPP_TEMPLATE_FEE=
MSG91_WHATSAPP_TEMPLATE_ATTENDANCE=

# Razorpay (get from razorpay.com/dashboard)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Super Admin Setup (used by dbSetup.js)
SUPER_ADMIN_EMAIL=superadmin@system.com
SUPER_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
